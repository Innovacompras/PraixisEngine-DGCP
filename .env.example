# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED IN ALL MODES
# ──────────────────────────────────────────────────────────────────────────────

# LLM Backend (any OpenAI-compatible server)
AI_API_URL=http://localhost:8081      # Base URL of your OpenAI-compatible LLM server
AI_API_KEY=your-llm-api-key           # API key for the LLM server (can be any string for local setups)
MODEL_NAME=gemma3:12b                 # Model name as recognized by your LLM server

# Admin panel credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# ──────────────────────────────────────────────────────────────────────────────
# REDIS
#
# Required when running locally (uv run ...) or via `make up` (API-only docker
# compose — you bring your own Redis). Auto-overridden by docker-compose.local.yml
# when you run `make up-local`, so you can leave it unset for that mode.
# ──────────────────────────────────────────────────────────────────────────────

# Local: redis://localhost:6379/0
# With password: redis://:password@host:6379/0
# TLS (Upstash, remote): rediss://:password@host:6380/0
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# TUNABLES (sensible defaults — override only if you need to)
# ──────────────────────────────────────────────────────────────────────────────

# Session
SESSION_TTL=86400                     # Session expiry in seconds (default: 24 hours)
MAX_HISTORY_PAIRS=20                  # Max user+assistant turns kept per session before oldest are trimmed

# Vector store (embedded ChromaDB — runs in-process, persists to a local directory).
# Defaults to chroma_data/ in the project root. Inside Docker this resolves to
# /app/chroma_data, which docker-compose.yml mounts as a named volume so data
# survives container restarts.
# CHROMA_PATH=/absolute/path/to/chroma_data

# Embedding model (used by the RAG pipeline for document and query vectors).
# Must be a model name supported by fastembed. Change requires re-uploading all collections.
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LLM concurrency
# Total simultaneous LLM calls allowed across the entire deployment. Enforced
# globally via a Redis-backed token bucket, so the cap holds across multiple
# uvicorn workers and container replicas sharing the same Redis. Set to 1 for
# a large model on a single GPU; raise it if your backend has headroom.
GPU_CONCURRENCY=2
# Max seconds a request waits for a free slot before returning 503.
GPU_WAIT_TIMEOUT=30
# Per-worker cap on concurrent LLM calls inside the file_summary map-reduce
# pipeline. Only has effect when lower than GPU_CONCURRENCY — use it to
# reserve global slots for chat/RAG requests while a large file is processed.
CHUNK_CONCURRENCY=4
