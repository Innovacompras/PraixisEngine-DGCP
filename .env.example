# LLM Backend
AI_API_URL=http://localhost:8081      # Base URL of your OpenAI-compatible LLM server
AI_API_KEY=your-llm-api-key          # API key for the LLM server (can be any string for local setups)
MODEL_NAME=gemma3:12b                # Model name as recognized by your LLM server

# Redis
# For a local Redis instance:
REDIS_URL=redis://localhost:6379/0
# For a remote TLS instance (e.g. Upstash):
# REDIS_URL=rediss://default:<password>@<host>:6379

# Session
SESSION_TTL=86400                    # Session expiry in seconds (default: 24 hours)
MAX_HISTORY_PAIRS=20                 # Max user+assistant turns kept per session before oldest are trimmed

# Vector store (PostgreSQL + pgvector)
# When running via docker-compose, use the service name as the host:
#   POSTGRES_URL=postgresql://praixis:yourpassword@postgres:5432/praixis
# For an external Postgres server (or local dev without Docker), use localhost:
POSTGRES_URL=postgresql://praixis:yourpassword@localhost:5432/praixis

# Embedding model (used by the RAG pipeline for document and query vectors)
# Must be a model name supported by fastembed. Change requires re-uploading all collections.
# EMBEDDING_DIMS must match the model's output dimension — startup will fail with a
# clear error if they don't. Both must be set together when overriding the default.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMS=384

# LLM concurrency
# Total simultaneous LLM calls allowed across all requests.
# Set to 1 for a large model on a single GPU. Raise it if your backend has headroom.
GPU_CONCURRENCY=2
# Max seconds a request waits for a free slot before returning 503.
GPU_WAIT_TIMEOUT=30
# Global cap on concurrent LLM calls in the file_summary map-reduce pipeline.
# Only has effect when lower than GPU_CONCURRENCY — use it to reserve slots
# for chat/RAG requests while a large file is being processed.
CHUNK_CONCURRENCY=4

# Admin
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
